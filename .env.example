# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# MongoDB Connection String (REQUIRED)
# Format: mongodb://username:password@host:port/database?authSource=database
# Example: mongodb://useflora:password@192.168.1.10:27017/useflora?authSource=useflora
MONGO_URI=mongodb://user:password@host:port/database?authSource=database

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 8000)
PORT=8000

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Environment mode: development or production (default: development)
ENVIRONMENT=development

# Logging level: debug, info, warning, error, critical (default: info)
LOG_LEVEL=info

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS (comma-separated)
# Default: http://localhost:3000,http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# TAXONOMY API CONFIGURATION
# ============================================================================

# Timeout for taxonomy API requests (seconds)
TAXONOMY_API_TIMEOUT=5

# Cache time-to-live for taxonomy validations (days)
CACHE_TTL_DAYS=30

# ============================================================================
# SECURITY (Production Only)
# ============================================================================

# Secret key for JWT tokens (optional, for future authentication)
SECRET_KEY=your-secret-key-here
