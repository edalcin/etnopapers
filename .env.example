# ============================================================================
#  Etnopapers - Configuração de Ambiente
#
#  Este arquivo serve como template para configuração local.
#
#  Para usar:
#    1. Copie este arquivo para .env
#    2. Edite os valores conforme sua configuração
#    3. Reinicie a aplicação
#
#  IMPORTANTE: O arquivo .env não é versionado (está no .gitignore)
# ============================================================================

# ============================================================================
#  MongoDB Configuration (OBRIGATÓRIO)
# ============================================================================

# MongoDB connection URI
#
# Exemplos:
#   - MongoDB local:
#     MONGO_URI=mongodb://localhost:27017/etnopapers
#
#   - MongoDB com autenticação:
#     MONGO_URI=mongodb://username:password@localhost:27017/etnopapers
#
#   - MongoDB Atlas (cloud):
#     MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/etnopapers
#
MONGO_URI=mongodb://localhost:27017/etnopapers


# ============================================================================
#  Ollama Configuration
# ============================================================================

# Ollama service URL
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Ollama model name
# Default: qwen2.5:7b-instruct-q4_K_M
#
# Para listar modelos disponíveis:
#   ollama list
#
# Para baixar novo modelo:
#   ollama pull nome-do-modelo
#
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M


# ============================================================================
#  Server Configuration
# ============================================================================

# Server port
# Default: 8000
PORT=8000

# Server host
# Default: 0.0.0.0 (escuta em todas as interfaces)
HOST=0.0.0.0

# Environment mode
# Options: development, production
# Default: production
ENVIRONMENT=production

# Log level
# Options: debug, info, warning, error, critical
# Default: info
LOG_LEVEL=info


# ============================================================================
#  CORS Configuration
# ============================================================================

# Allowed CORS origins (comma-separated)
# Default: http://localhost:3000,http://localhost:8000
#
# Para desenvolvimento com frontend separado, adicione:
#   CORS_ORIGINS=http://localhost:3000,http://localhost:8000
#
# Para produção (standalone), pode manter o padrão
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# ============================================================================
#  Taxonomy API Configuration
# ============================================================================

# Timeout para chamadas à API de taxonomia (GBIF/Tropicos) em segundos
# Default: 5
TAXONOMY_API_TIMEOUT=5

# Tempo de cache para validações taxonômicas em dias
# Default: 30
CACHE_TTL_DAYS=30


# ============================================================================
#  Advanced Configuration (Opcional)
# ============================================================================

# Rate limiting (requests por minuto)
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_DOWNLOAD_PER_MINUTE=1

# Maximum upload file size (MB)
# MAX_UPLOAD_SIZE_MB=50

# Pagination defaults
# DEFAULT_PAGE_SIZE=50
# MAX_PAGE_SIZE=500
